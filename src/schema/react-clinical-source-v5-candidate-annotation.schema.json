{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "React Clinical Source V5 Candidate Annotation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "recordId",
    "source",
    "sourceDecision",
    "statement",
    "annotationDecision",
    "naturalSegments",
    "candidateRequiredEvidence",
    "traceFailures"
  ],
  "properties": {
    "schemaVersion": {
      "const": "react-clinical-source-v5-candidate-annotation"
    },
    "recordId": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "sourceDecision": {
      "type": "string",
      "minLength": 1
    },
    "statement": {
      "type": "string",
      "minLength": 1
    },
    "question": {
      "type": "string"
    },
    "annotationDecision": {
      "enum": ["usable", "needs_review", "unusable"]
    },
    "naturalSegments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["documentId", "segmentId", "text", "charStart", "charEnd", "role"],
        "properties": {
          "documentId": { "type": "string", "minLength": 1 },
          "segmentId": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 },
          "charStart": { "type": "integer", "minimum": 0 },
          "charEnd": { "type": "integer", "minimum": 1 },
          "role": {
            "enum": [
              "background",
              "methods",
              "results",
              "conclusion",
              "eligibility",
              "intervention",
              "outcome",
              "adverse_event",
              "other"
            ]
          }
        }
      }
    },
    "candidateRequiredEvidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["documentId", "segmentId", "stance", "confidence", "rationale"],
        "properties": {
          "documentId": { "type": "string", "minLength": 1 },
          "segmentId": { "type": "string", "minLength": 1 },
          "stance": { "enum": ["supports", "refutes", "mixed", "neutral"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "rationale": { "type": "string", "minLength": 1 }
        }
      }
    },
    "traceFailures": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    }
  }
}
